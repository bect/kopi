{
  "name": "{{ .name }}",
  "short_name": "{{ .short_name }}",
  "start_url": "{{ .start_url }}",
  "display": "{{ .display }}",
  "background_color": "{{ .background_color }}",
  "theme_color": "{{ .theme_color }}",
  "icons": [
    {{- range $idx, $icon := .icons -}}
      {{- if $idx }},{{ end }}
      {
        "src": "{{ $icon.src }}",
        "sizes": "{{ $icon.sizes }}",
        "type": "{{ $icon.type }}"
      }
    {{- end -}}
  ]
}
